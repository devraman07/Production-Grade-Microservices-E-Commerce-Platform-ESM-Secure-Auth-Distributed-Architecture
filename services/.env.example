# PodPlate Platform - Environment Configuration
# Copy this file to .env in each service directory and fill in the values

# ============================================
# COMMON CONFIGURATION (All Services)
# ============================================

# Environment
NODE_ENV=development
LOG_LEVEL=info
SERVICE_VERSION=1.0.0

# MongoDB
MONGODB_URI=mongodb://localhost:27017/podplate

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRE=30d

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Internal Service Authentication
INTERNAL_SERVICE_KEY=your-internal-service-key-for-service-to-service-auth

# Performance
MAX_QUERY_TIME=10000
SLOW_QUERY_THRESHOLD=500
ROUTE_TIMEOUT=30000

# ============================================
# SERVICE URLS (Inter-service Communication)
# ============================================

API_GATEWAY_URL=http://localhost:3000
AUTH_SERVICE_URL=http://localhost:3001
USER_SERVICE_URL=http://localhost:3002
PRODUCT_SERVICE_URL=http://localhost:3003
RESTAURANT_SERVICE_URL=http://localhost:3004
CART_SERVICE_URL=http://localhost:3005
ORDER_SERVICE_URL=http://localhost:3006
PAYMENT_SERVICE_URL=http://localhost:3007
NOTIFICATION_SERVICE_URL=http://localhost:3008

# ============================================
# SERVICE-SPECIFIC PORTS
# ============================================

# API Gateway
PORT=3000

# Auth Service
AUTH_PORT=3001

# User Service
USER_PORT=3002

# Product Service
PRODUCT_PORT=3003

# Restaurant Service
RESTAURANT_PORT=3004

# Cart Service
CART_PORT=3005

# Order Service
ORDER_PORT=3006

# Payment Service
PAYMENT_PORT=3007

# Notification Service
NOTIFICATION_PORT=3008

# ============================================
# SERVICE-SPECIFIC CONFIGURATION
# ============================================

# Cart Service
REDIS_URL=redis://localhost:6379

# Payment Service (Stripe)
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Email/Notification Service
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Cloud Storage (AWS S3 or similar)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=podplate-uploads

# ============================================
# PRODUCTION-ONLY SETTINGS
# ============================================

# SSL/TLS
# SSL_KEY_PATH=/path/to/privkey.pem
# SSL_CERT_PATH=/path/to/fullchain.pem

# Rate Limiting (more strict in production)
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=100

# Logging (structured JSON in production)
# LOG_FORMAT=json
