# ============================================================================
# PODPLATE PRODUCTION ENVIRONMENT TEMPLATE
# ============================================================================
# Copy this to .env.production and fill in real values from your secure vault
# NEVER commit .env.production to Git - only this template
# ============================================================================

# ============================================================================
# 🌐 FRONTEND (Next.js) - Build-time & Runtime
# ============================================================================
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
NEXT_PUBLIC_APP_ENV=production
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key

# ============================================================================
# 🚪 API GATEWAY (Port 3000)
# ============================================================================
PORT=3000
NODE_ENV=production
CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com
LOG_LEVEL=info
REQUEST_TIMEOUT=30000

# Service URLs (internal network - use service names in Docker/K8s)
AUTH_SERVICE_URL=http://auth-service:3001
USER_SERVICE_URL=http://user-service:3002
PRODUCT_SERVICE_URL=http://product-service:3003
RESTAURANT_SERVICE_URL=http://restaurant-service:3004
CART_SERVICE_URL=http://cart-service:3005
ORDER_SERVICE_URL=http://order-service:3006
PAYMENT_SERVICE_URL=http://payment-service:3007
NOTIFICATION_SERVICE_URL=http://notification-service:3008

# Internal service-to-service auth
INTERNAL_SERVICE_KEY=generate-a-32-char-random-secret-key

# ============================================================================
# 🔐 AUTH SERVICE (Port 3001) - uses DATABASE_URL
# ============================================================================
PORT=3001
NODE_ENV=production
SERVICE_NAME=auth-service
LOG_LEVEL=info

# Database (Auth DB)
DATABASE_URL=postgresql://auth_user:password@your-neon-host/auth_db?sslmode=require

# JWT Configuration (use strong secrets: openssl rand -base64 32)
JWT_SECRET=your-jwt-secret-min-32-chars-long
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars-long
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Cookies
COOKIE_DOMAIN=.yourdomain.com
COOKIE_SECURE=true
COOKIE_SAME_SITE=strict

# ============================================================================
# 👤 USER SERVICE (Port 3002) - uses DATABASE_URL
# ============================================================================
PORT=3002
NODE_ENV=production
SERVICE_NAME=user-service
LOG_LEVEL=info

# Database (User DB)
DATABASE_URL=postgresql://user_user:password@your-neon-host/user_db?sslmode=require

# For token verification
AUTH_SERVICE_URL=http://auth-service:3001

# ============================================================================
# 📦 PRODUCT SERVICE (Port 3003) - uses DATABASE_URL
# ============================================================================
PORT=3003
NODE_ENV=production
SERVICE_NAME=product-service
LOG_LEVEL=info

# Database (Product DB)
DATABASE_URL=postgresql://product_user:password@your-neon-host/product_db?sslmode=require

# File uploads (S3 bucket recommended)
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880
CDN_BASE_URL=https://your-cdn.cloudfront.net

# ============================================================================
# 🍽️ RESTAURANT SERVICE (Port 3004) - uses DATABASE_URL
# ============================================================================
PORT=3004
NODE_ENV=production
SERVICE_NAME=restaurant-service
LOG_LEVEL=info

# Database (Restaurant DB)
DATABASE_URL=postgresql://restaurant_user:password@your-neon-host/restaurant_db?sslmode=require

# ============================================================================
# 🛒 CART SERVICE (Port 3005) - uses REDIS (no PostgreSQL)
# ============================================================================
PORT=3005
NODE_ENV=production
SERVICE_NAME=cart-service
LOG_LEVEL=info

# Redis (ElastiCache or Redis Cloud)
REDIS_URL=redis://your-redis-host:6379
REDIS_PASSWORD=your-redis-password

# Session
SESSION_SECRET=generate-a-32-char-session-secret

# ============================================================================
# 📋 ORDER SERVICE (Port 3006) - uses DATABASE_URL
# ============================================================================
PORT=3006
NODE_ENV=production
SERVICE_NAME=order-service
LOG_LEVEL=info

# Database (Order DB)
DATABASE_URL=postgresql://order_user:password@your-neon-host/order_db?sslmode=require

# Internal service URLs
CART_SERVICE_URL=http://cart-service:3005
PAYMENT_SERVICE_URL=http://payment-service:3007
NOTIFICATION_SERVICE_URL=http://notification-service:3008

# ============================================================================
# 💳 PAYMENT SERVICE (Port 3007) - uses DATABASE_URL
# ============================================================================
PORT=3007
NODE_ENV=production
SERVICE_NAME=payment-service
LOG_LEVEL=info

# Database (Payment DB)
DATABASE_URL=postgresql://payment_user:password@your-neon-host/payment_db?sslmode=require

# Stripe (get from Stripe Dashboard)
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# Order service URL
ORDER_SERVICE_URL=http://order-service:3006

# ============================================================================
# 🔔 NOTIFICATION SERVICE (Port 3008) - uses DATABASE_URL
# ============================================================================
PORT=3008
NODE_ENV=production
SERVICE_NAME=notification-service
LOG_LEVEL=info

# Database (Notification DB)
DATABASE_URL=postgresql://notification_user:password@your-neon-host/notification_db?sslmode=require

# Email (SendGrid)
SENDGRID_API_KEY=SG.your_sendgrid_api_key
EMAIL_FROM=noreply@yourdomain.com

# SMS (Twilio)
TWILIO_ACCOUNT_SID=AC_your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Frontend URL (for email links)
FRONTEND_URL=https://yourdomain.com
